{
  "name": "atlas",
  "version": "1.0.6",
  "description": "An auto-play tool for report videos with the latest features",
  "keywords": [
    "auto-play",
    "chrome-extension",
    "education"
  ],
  "license": "MIT",
  "author": "operationcheck",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:firefox": "bun run build && bun scripts/build-firefox.ts",
    "preview": "vite preview",
    "typecheck": "tsc",
    "lint": "oxlint --quiet .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:write": "oxfmt ."
  },
  "dependencies": {
    "lucide-react": "^0.507.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.32",
    "@types/archiver": "^7.0.0",
    "@types/chrome": "0.0.318",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@types/webextension-polyfill": "^0.12.3",
    "@vitejs/plugin-react": "^4.4.1",
    "archiver": "^7.0.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "terser": "^5.39.0",
    "typescript": "5.8.3",
    "vite": "6.3.4"
  },
  "packageManager": "bun"
}
