{
  "name": "atlas",
  "version": "1.0.6",
  "description": "An auto-play tool for report videos with the latest features",
  "keywords": [
    "auto-play",
    "chrome-extension",
    "education"
  ],
  "license": "MIT",
  "author": "operationcheck",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt zip -b firefox",
    "preview": "wxt preview",
    "typecheck": "tsc --noEmit",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "lint": "oxlint --quiet .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:write": "oxfmt ."
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/module-react": "^1.1.5",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "6.0.2",
    "wxt": "^0.20.20"
  },
  "packageManager": "bun"
}
